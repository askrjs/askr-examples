{
  "name": "@askrjs/example-ssg",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --host 127.0.0.1 --port 3003",
    "start": "node serve.mjs",
    "build": "npm run build:client && npm run generate",
    "build:client": "vp build --configLoader native",
    "generate": "askr ssg --config ./ssg.config.ts --output ./dist/static",
    "generate:incremental": "npm run generate -- --incremental",
    "fmt": "vp fmt .",
    "lint": "vp lint .",
    "test": "vp test run",
    "typecheck": "tsc --noEmit --pretty false",
    "check": "npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "@askrjs/askr": "file:../../askr",
    "@askrjs/lucide": "file:../../askr-lucide",
    "@askrjs/themes": "file:../../askr-themes",
    "@askrjs/ui": "file:../../askr-ui"
  },
  "devDependencies": {
    "@askrjs/cli": "file:../../askr-cli",
    "@askrjs/vite": "file:../../askr-vite",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plus": "^0.2.4",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}

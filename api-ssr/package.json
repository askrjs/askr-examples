{
  "name": "@askrjs/example-api-ssr",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --host 127.0.0.1 --port 3002",
    "start": "node serve.mjs",
    "build": "vp build --configLoader native && vp build --ssr src/server/production.ts --outDir dist/server --configLoader native",
    "preview": "vp preview --host 127.0.0.1 --port 4002",
    "fmt": "vp fmt .",
    "lint": "vp lint .",
    "test": "vp test run",
    "typecheck": "tsc --noEmit --pretty false",
    "openapi": "askr openapi",
    "openapi:check": "askr openapi --check",
    "check": "npm run lint && npm run typecheck && npm test && npm run openapi:check"
  },
  "dependencies": {
    "@askrjs/askr": ">=0.0.52 <0.1.0",
    "@askrjs/auth": ">=0.0.1 <0.1.0",
    "@askrjs/charts": ">=0.1.1 <0.2.0",
    "@askrjs/i18n": ">=0.0.1 <0.1.0",
    "@askrjs/lucide": ">=0.0.3 <0.1.0",
    "@askrjs/monaco": ">=0.0.1 <0.1.0",
    "@askrjs/node": ">=0.0.1 <0.1.0",
    "@askrjs/otel": ">=0.0.1 <0.1.0",
    "@askrjs/schema": ">=0.0.1 <0.1.0",
    "@askrjs/server": ">=0.0.1 <0.1.0",
    "@askrjs/themes": ">=0.0.11 <0.1.0",
    "@askrjs/ui": ">=0.0.12 <0.1.0",
    "@opentelemetry/api": "^1.9.0",
    "monaco-editor": "^0.56.0"
  },
  "devDependencies": {
    "@askrjs/cli": ">=0.0.2 <0.1.0",
    "@askrjs/vite": ">=0.0.5 <0.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plus": "^0.2.4",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}

{
  "name": "@askrjs/example-api-only",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "start": "node --import tsx src/server.ts",
    "build": "tsc --noEmit --pretty false",
    "fmt": "vp fmt .",
    "lint": "vp lint .",
    "test": "vp test run",
    "typecheck": "tsc --noEmit --pretty false",
    "openapi": "askr openapi",
    "openapi:check": "askr openapi --check",
    "check": "npm run lint && npm run typecheck && npm test && npm run openapi:check"
  },
  "dependencies": {
    "@askrjs/auth": "file:../../askr-auth",
    "@askrjs/node": "file:../../askr-node",
    "@askrjs/server": "file:../../askr-server"
  },
  "devDependencies": {
    "@askrjs/cli": "file:../../askr-cli",
    "tsx": "^4.23.0",
    "typescript": "^6.0.0",
    "vite-plus": "^0.2.4",
    "vitest": "^4.0.0"
  },
  "engines": { "node": ">=18" }
}

{
  "name": "@askrjs/example-api-only",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json --pretty false",
    "fmt": "vp fmt .",
    "lint": "vp lint .",
    "test": "vp test run",
    "typecheck": "tsc --noEmit --pretty false",
    "openapi": "askr openapi",
    "openapi:check": "askr openapi --check",
    "check": "npm run lint && npm run typecheck && npm test && npm run openapi:check"
  },
  "dependencies": {
    "@askrjs/auth": ">=0.0.1 <0.1.0",
    "@askrjs/node": ">=0.0.1 <0.1.0",
    "@askrjs/schema": ">=0.0.1 <0.1.0",
    "@askrjs/server": ">=0.0.1 <0.1.0"
  },
  "devDependencies": {
    "@askrjs/cli": ">=0.0.2 <0.1.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.4",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
